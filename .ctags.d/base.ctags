# be sure to use universal-ctags not exuberant-ctags

--exclude=*.md
--exclude=*.min.js
--exclude=*.svg
--exclude=.elixir_ls
--exclude=.gemini
--exclude=.git
--exclude=.next
--exclude=.swc
--exclude=_build
--exclude=coverage
--exclude=deps
--exclude=dist
--exclude=gulp
--exclude=node_modules
--exclude=priv
--exclude=public
--exclude=tmp
--exclude=vendor
--map-TypeScript=+.tsx
--recurse=yes
