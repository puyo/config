[core]
	excludesfile = ~/.gitignore
	pager = delta
[color]
	ui = true
[push]
	default = simple
[user]
	name = Gregory McIntyre
	email = greg@gregorymcintyre.com
[color "diff-highlight"]
	oldNormal = red bold
	oldHighlight = red bold 52
	newNormal = green bold
	newHighlight = green bold 22
[credential]
	helper = store
[alias]
	# one-line log
	l = log --pretty=format:"%C(yellow)%h\\ %ad%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --date=short

	a = add
	ap = add -p
	c = commit --verbose
	ca = commit -a --verbose
	cm = commit -m
	cam = commit -a -m
	m = commit --amend --verbose

	d = diff
	ds = diff --stat
	dc = diff --cached

	s = status -sb
	co = checkout
	cob = checkout -b
	cop = checkout -p

	# list branches sorted by last modified
	b = "!git for-each-ref --sort='-authordate' --format='%(authordate:short)%09%(objectname:short)%09%(authorname)%09%(refname:short)' refs/heads | ~/bin/tablize"

	# list aliases
	la = "!git config -l | grep alias | cut -c 7-"

	cb = rev-parse --symbolic-full-name --abbrev-ref HEAD
	gp = !git push --set-upstream origin HEAD:$(git cb)
	up = !git fetch --prune origin && git rebase --autostash --rebase-merges origin/$(git cb)
	gup = !git fetch --prune origin && git rebase --autostash --rebase-merges origin/$(git cb)

	stashpull = !git pull --rebase --autostash

  # Git, so easy eh
  cleanup = ! ( main=$(git rev-parse --abbrev-ref origin/HEAD | sed s:origin/::) && git branch --merged "origin/${main}" | grep -v "\\\\b${main}\\\\b" | xargs --no-run-if-empty --max-args=1 git branch -d )

	tags = !.git/hooks/ctags

[diff]
	renameLimit = 2000
	noprefix = true
	relative = true
[filter "media"]
	required = true
	clean = git media clean %f
	smudge = git media smudge %f
[color "diff"]
	meta = yellow
	frag = magenta bold
	commit = yellow bold
	old = red bold
	new = green bold
	whitespace = red reverse
[init]
	templatedir = ~/.git_template
	defaultBranch = main
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[submodule]
	recurse = true
[github]
	user = puyo
[grep]
	patternType = perl
[advice]
	skippedCherryPicks = false
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	dark = true
	minus-style       = syntax "#3a1418"
	minus-emph-style  = syntax "#6e2230"
	plus-style        = syntax "#0e2a16"
	plus-emph-style   = syntax "#1c5a2e"
[merge]
	conflictStyle = zdiff3
[rebase]
	autoStash = true
[includeIf "gitdir:~/f/"]
    path = ~/f/.gitconfig
